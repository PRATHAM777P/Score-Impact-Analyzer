# ─────────────────────────────────────────────
#  Score Impact Analyzer — .gitignore
# ─────────────────────────────────────────────

# ── Secrets & Environment ─────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
*.pfx

# ── Student Data (NEVER commit real data) ─────
data/
reports/
*.json
# Re-allow the scoring model (not student data)
!scoring_DSAT_v2.json

# ── Python ────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.eggs
*.egg
MANIFEST

# ── Virtual Environments ──────────────────────
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/
.python-version

# ── Testing & Coverage ────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
nosetests.xml
test-results/

# ── IDEs & Editors ────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────
logs/
*.log
*.log.*

# ── OS ────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Desktop.ini
$RECYCLE.BIN/

# ── Jupyter ───────────────────────────────────
.ipynb_checkpoints
*.ipynb

# ── mypy ──────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json

# ── Ruff / linting ────────────────────────────
.ruff_cache/
